{
  "name": "cashkr-laptop-auto-detect",
  "version": "1.0.0",
  "description": "Auto-detect laptop hardware specs for Cashkr",
  "main": "dist/main.js",
  "scripts": {
    "build:ts": "tsc",
    "start": "tsc && electron .",
    "build": "tsc && electron-builder",
    "build:mac": "tsc && electron-builder -m",
    "build:win": "tsc && electron-builder -w",
    "build:win:stage": "tsc && electron-builder -w --config.extraMetadata.apiUrl=https://stage.rkhsacweb.cashkr.com/api/qc/laptop",
    "build:win:prod": "tsc && electron-builder -w --config.extraMetadata.apiUrl=https://www.cashkr.com/api/qc/laptop"
  },
  "keywords": [],
  "author": "Cashkr",
  "license": "ISC",
  "packageManager": "pnpm@10.19.0",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "typescript": "^5.7.0"
  },
  "build": {
    "appId": "com.cashkr.laptopdetect",
    "productName": "Cashkr Hardware Detector",
    "icon": "assets/favicon.png",
    "asar": true,
    "compression": "maximum",
    "files": [
      "dist/*.js",
      "index.html",
      "styles.css",
      "assets/favicon.png",
      "assets/icon.icns",
      "assets/logo.png"
    ],
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/favicon.png",
      "cscLink": "certificate.pfx",
      "cscKeyPassword": "Cashkr@2024"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": false,
      "perMachine": false,
      "runAfterFinish": true
    }
  },
  "dependencies": {}
}